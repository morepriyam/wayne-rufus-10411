{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "shell",
			"command": "./gradlew build",
			"problemMatcher": [
				"$java"
			],
			"group": "build"
		},
		{
			"label": "Deploy",
			"type": "shell",
			"command": "./gradlew deploy",
			"problemMatcher": [
				"$java"
			],
